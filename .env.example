# ─────────────────────────────────────────────────────────────────────────────
# VELOX — Variables de Entorno
# Copia este archivo como .env.local y completa todos los valores
# NUNCA commitees .env.local al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Para desarrollo local: postgresql://postgres:password@localhost:5432/velox
# Para producción: usa la URL de Supabase / Railway / Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/velox"

# Direct connection (para migraciones — bypass pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/velox"

# ── Autenticación (Clerk) ─────────────────────────────────────────────────────
# Obtener en: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# URLs de redirect post-auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ── IA (Anthropic) ────────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── Redis (para BullMQ — workers de alertas Fase 2) ───────────────────────────
# Para desarrollo local: redis://localhost:6379
# Para producción: usa Upstash Redis (https://upstash.com)
REDIS_URL="redis://localhost:6379"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Velox <hola@velox.app>"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Opcional: Monitoreo ───────────────────────────────────────────────────────
# SENTRY_DSN="https://..."
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
